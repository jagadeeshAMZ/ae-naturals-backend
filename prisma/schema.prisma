// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum Role {
  ADMIN
  USER
}

enum ProviderType {
  EMAIL
  SMS
  PAYMENT
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  PHONEPE
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// models
model User {
  id        String     @id @default(cuid())
  email     String?    @unique // Changed to optional for phone-only users
  phone     String     @unique // Added for mobile authentication
  name      String
  gender    Gender?
  role      Role       @default(USER)
  lastLogin DateTime   @default(now()) // Added for session tracking
  orders    Order[]
  cart      Cart?
  // Add these two lines to satisfy the relation requirements
  accounts  Account[]
  sessions  Session[]
  addresses Address[]
  wishlist  Wishlist[]
  reviews   Review[]
  createdAt DateTime   @default(now())
}

model Store {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  domain        String?  @unique // e.g., "flowerfairy.com" or "store1.localhost"
  isDefault     Boolean  @default(false) // Fallback store
  industry      String
  paymentConfig Json?
  themeConfig   Json?
  createdAt     DateTime @default(now())

  products      Product[]
  orders        Order[]
  shippingRules ShippingRule[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  name        String
  slug        String   @unique
  description String?
  price       Float // Base Price
  oldPrice    Float? // MRP
  images      String[]

  // Specific Metadata
  ingredients      String?
  careInstructions String[] // ["Store below 5°C", "Consume within 24h"]
  deliveryInfo     String[] // ["Same day delivery", "Free over ₹999"]

// NEW: Relation to Extra details
  extra       ProductExtra?

  // Flipkart-style Attribute System
  attributes  ProductAttribute[]
  variants    ProductVariant[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  category    Category           @relation(fields: [categoryId], references: [id])
  categoryId  String
  rating      Float              @default(4.5)
  reviewCount Int                @default(0)
  wishlist    Wishlist[]
  reviews     Review[]
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
}

model ProductAttribute {
  id        String  @id @default(cuid())
  name      String // e.g., "Weight", "Size", "Stems"
  value     String // e.g., "1kg", "Large", "12 Stems"
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String // e.g., "Eggless", "With Vase"
  priceModifier Float   @default(0) // Added to base price
  stock         Int     @default(0)
}

// NEW MODEL
model ProductExtra {
  id              String   @id @default(cuid())
  productId       String   @unique
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Important Info (Rich Text / Long Strings)
  safetyInfo      String?  @db.Text
  ingredients     String?  @db.Text
  directions      String?  @db.Text
  legalDisclaimer String?  @db.Text

  // Product Details Table
  manufacturer    String?
  countryOfOrigin String?
  weight          String?
  dimensions      String?
  genericName     String?

  // A+ Content Builder Data
  aPlusContent    Json?    // Stores array of block objects e.g., [{ type: 'banner', image: '...', text: '...' }]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Order {
  id                String           @id @default(cuid())
  storeId           String
  userId            String
  totalAmount       Float
  status            OrderStatus      @default(PENDING)
  items             OrderItem[]
  paymentProvider   PaymentProvider?
  paymentProviderId String?          @unique
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id])
  store             Store            @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float // Snapshot of price at purchase
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model ShippingRule {
  id             String  @id @default(cuid())
  storeId        String
  store          Store   @relation(fields: [storeId], references: [id])
  pincode        String
  deliveryCharge Float
  isOperational  Boolean @default(true)

  @@index([storeId, pincode])
}

// Add these to your schema.prisma
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token]) // Compound key for security
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  price     Float // Snapshot of price when added
  createdAt DateTime @default(now())

  @@unique([cartId, productId])
}

model ProviderConfig {
  id        String       @id @default(cuid())
  type      ProviderType
  provider  String // e.g., "SMTP", "AWS_SES", "FAST2SMS", "RAZORPAY"
  isActive  Boolean      @default(false)
  priority  Int          @default(1) // 1 is highest priority
  config    String       @db.Text // Store ENCRYPTED stringified JSON
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([type, provider])
}

model NotificationLog {
  id        String   @id @default(cuid())
  type      String // "EMAIL", "SMS"
  provider  String
  recipient String
  status    String // "SUCCESS", "FAILED"
  error     String?  @db.Text
  createdAt DateTime @default(now())
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  name        String
  phone       String
  addressLine String
  city        String
  state       String
  pincode     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int      @default(5) // 1 to 5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
